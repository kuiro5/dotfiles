[init]
  defaultBranch = main

[core]
  excludesfile = ~/.gitignore_global
  editor = nvim
[user]
  name = Josh Kuiros
  email = joshkuiros@gmail.com
[pull]
  rebase = true
[color]
  ui = true
[alias]
  a=add
  aa=add --all
  ap=add -p
  b=branch
  c=commit -v
  cam=commit -a -m
  cb=checkout -b
  cmsg=commit -m
  co=checkout
  d=diff
  f=fetch
  gl=pull
  gp=push
  gpf=push --force
  lg=log --stat
  m=merge
  st=status
  sta=stash save
  stp=stash pop
